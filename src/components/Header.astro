---
import { SITE_TITLE } from '../data/site';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { url: '/',              title: 'Home'     },
  { url: '/wiki/',         title: 'Wiki'     },
  { url: '/trello/',       title: 'Trello'   },
  { url: '/codes/',        title: 'Codes'    },
  { url: '/controls/',     title: 'Controls' },
  { url: '/beginner-guide/', title: 'Beginner' },
];
---

<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="/" aria-label={`${SITE_TITLE} — Home`}>
      <span class="mark" aria-hidden="true">
        <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="8.5,1 12,6.5 8.5,16 5,6.5" fill="white"/>
          <rect x="5" y="7.25" width="7" height="2.5" rx="1.25" fill="white"/>
        </svg>
      </span>
      <span><strong>Demon Born Compass</strong><span>Help Hub</span></span>
    </a>

    <nav class="nav" aria-label="Primary navigation">
      {navItems.map(item => (
        <a
          href={item.url}
          aria-current={currentPath === item.url ? 'page' : undefined}
        >
          {item.title}
        </a>
      ))}
      <a href="/about/">About</a>
    </nav>
  </div>
</header>
