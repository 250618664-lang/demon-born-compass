---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import EvidenceBadge from '../components/EvidenceBadge.astro';
import { EVIDENCE_STATUS } from '../data/site';

interface Props {
  title: string;
  description?: string;
  canonicalUrl: string;
  ogType?: string;
  breadcrumb?: { label: string; url: string }[];
  evidenceNotes?: string;
  sourceIds?: string[];
}

const {
  title,
  description,
  canonicalUrl,
  ogType = 'article',
  breadcrumb,
  evidenceNotes,
  sourceIds = [],
} = Astro.props;

const baseLayoutBreadcrumb = breadcrumb
  ? breadcrumb.map(b => ({ name: b.label, url: b.url }))
  : [];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType={ogType}
  breadcrumb={baseLayoutBreadcrumb}
>
  <div class="prose-container">
    {breadcrumb && breadcrumb.length > 0 && (
      <Breadcrumb items={breadcrumb} />
    )}

    <slot />

    <!-- Evidence + citations footer -->
    <div class="evidence-footer">
      <EvidenceBadge
        status={EVIDENCE_STATUS}
        notes={evidenceNotes}
      />

      {sourceIds.length > 0 && (
        <div data-source-ids={sourceIds.join(',')} aria-hidden="true" style="display:none"></div>
      )}

      <p class="evidence-footer-meta">
        Full source registry:
        <a href="/sources/">Sources &amp; Corrections</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .evidence-footer {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .evidence-footer-meta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>