---
import ContentLayout from '../layouts/ContentLayout.astro';
import { CURRENT_VERSION, EVIDENCE_REVIEW_DATE } from '../data/site';

const pageSourceIds = ['DB-API-001', 'DB-API-005'];

const checklist = [
  { num: 1, title: 'Open the official Roblox game page', body: 'Start from the source, not from copied links. Check the description for pinned codes or updates.', done: true },
  { num: 2, title: 'Scan the controls page', body: 'Know the confirmed key labels before your first run. <a href="/controls/">See Controls page</a>.', done: true },
  { num: 3, title: 'Check code source status', body: 'Do not waste time on unverified code lists. <a href="/codes/">See Codes Status</a>.', done: false },
  { num: 4, title: 'Understand what not to trust yet', body: 'First quest, stat allocation, route unlock, tier lists, and best builds are not confirmed.', done: false },
  { num: 5, title: 'Choose your route direction', body: 'Two routes exist: Slayer (fight demons) or Demon (embrace dark side). Do not commit to detailed builds yet.', done: false },
];

const assetMap = [
  { name: 'Play platform', status: 'Can use now', pillClass: 'pill-now', note: 'Available on Roblox now' },
  { name: 'Controls', status: 'Can use now', pillClass: 'pill-now', note: '9 key labels confirmed' },
  { name: 'Route premise', status: 'Limited', pillClass: 'pill-hold', note: 'Two routes confirmed; details not yet' },
  { name: 'Codes', status: 'Do not trust yet', pillClass: 'pill-blocked', note: 'No official source confirmed' },
  { name: 'Builds', status: 'Do not trust yet', pillClass: 'pill-blocked', note: 'Tier lists and best builds not published' },
  { name: 'First quest', status: 'Do not trust yet', pillClass: 'pill-blocked', note: 'Requires hands-on play to document' },
];
---

<ContentLayout
  title="Demon Born Starter Checklist"
  description="Demon Born starter checklist — safe facts before you play, not a full walkthrough."
  canonicalUrl="/beginner-guide/"
  breadcrumb={[{ label: 'Starter Checklist', url: '/beginner-guide/' }]}
  evidenceNotes="Official confirmed limited — starter facts only; no first quest, stat allocation, or route unlock method published"
  sourceIds={pageSourceIds}
>
  <div class="workstation-container">
    <h1>Demon Born Starter Checklist</h1>

    <!-- Quick Answer Panel -->
    <div class="quick-answer-panel">
      <div class="qap-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Quick Answer
      </div>
      <p class="qap-body">
        This is not a full walkthrough yet. It is a safe starter checklist based only on confirmed public information. Use it to know what is safe to trust before or during your first session.
      </p>
    </div>

    <!-- Progress card + clickable checklist -->
    <div class="progress-card" style="margin-top: 22px">
      <strong>Pre-play progress</strong>
      <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
      <span id="progress-label">2 of {checklist.length} checked</span>
    </div>

    <div class="check-list" style="margin-top: 22px" id="checklist">
      {checklist.map(item => (
        <div class="check-item" data-done={item.done ? 'true' : 'false'}>
          <span class="number">{item.num}</span>
          <div>
            <strong>{item.title}</strong>
            <span set:html={item.body}></span>
          </div>
          <button
            class="check-action"
            type="button"
            aria-label={`Mark step ${item.num} as done`}
            data-checked={item.done ? 'true' : 'false'}
          >
            {item.done ? 'OK' : '+'}
          </button>
        </div>
      ))}
    </div>

    <!-- Confirmed facts — below checklist -->
    <h2 style="margin-top: var(--space-10)">Confirmed facts before you play</h2>
    <div class="can-cannot">
      <div class="can-col">
        <div class="col-heading">Yes — safe to use</div>
        <ul class="col-list">
          <li>Identity, title, creator</li>
          <li>Official control key labels</li>
          <li>Genre and setting (open world)</li>
          <li>Two-route premise (Slayer / Demon)</li>
          <li>Wiki and Trello status check</li>
          <li>Codes source checker</li>
        </ul>
      </div>
      <div class="cannot-col">
        <div class="col-heading">No — do not trust yet</div>
        <ul class="col-list">
          <li>First quest or tutorial steps</li>
          <li>Stat allocation system</li>
          <li>Route unlock method</li>
          <li>Character creation details</li>
          <li>Breathing styles and demon arts</li>
          <li>Clans or class system</li>
          <li>Crafting, mining, fishing</li>
          <li>Active codes (wait for official)</li>
          <li>Tier list or best build</li>
        </ul>
      </div>
    </div>

    <!-- Quick status -->
    <div class="guide-meta">
      <span class="meta-chip">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <rect x="1.5" y="1.5" width="9" height="9" rx="2" stroke="currentColor" stroke-width="1.2"/>
          <path d="M4 6h4M4 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        {CURRENT_VERSION}
      </span>
      <span class="meta-chip meta-warn">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M6 2v5M6 9v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
        </svg>
        Detailed steps require hands-on testing
      </span>
      <span class="meta-chip">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Last checked: {EVIDENCE_REVIEW_DATE}
      </span>
    </div>

    <!-- Mini asset map -->
    <h2>Can I use this info? (status map)</h2>
    <div class="asset-map">
      {assetMap.map(a => (
        <div class="asset-item">
          <div>
            <div class="asset-name">{a.name}</div>
            <div style="font-size: 0.75rem; color: var(--color-text-muted);">{a.note}</div>
          </div>
          <span class={`simple-status-pill ${a.pillClass}`}>{a.status}</span>
        </div>
      ))}
    </div>

    <!-- Official resources -->
    <h2>Official resources</h2>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Resource</th>
            <th>URL</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Official game page</td>
            <td><a href="https://www.roblox.com/games/79833666916700/Demon-Born" rel="noopener noreferrer" target="_blank">roblox.com/games/79833666916700/Demon-Born</a></td>
          </tr>
          <tr>
            <td>SoraExp Roblox group</td>
            <td><a href="https://groups.roblox.com/v1/groups/34709042" rel="noopener noreferrer" target="_blank">groups.roblox.com/v1/groups/34709042</a></td>
          </tr>
        </tbody>
      </table>
    </div>

    <p>
      If you have verified official information or hands-on observations to share,
      use the <a href="/contact/">correction workflow</a>.
      All published gameplay facts require either an official source or documented hands-on testing.
    </p>
  </div>
</ContentLayout>

<script>
  // Clickable checklist with progress bar
  const checkItems = document.querySelectorAll<HTMLElement>('.check-item');
  const progressFill = document.getElementById('progress-fill');
  const progressLabel = document.getElementById('progress-label');
  const total = checkItems.length;

  function updateProgress() {
    const done = document.querySelectorAll<HTMLElement>('.check-item[data-done="true"]').length;
    if (progressFill) {
      progressFill.style.width = `${(done / total) * 100}%`;
    }
    if (progressLabel) {
      progressLabel.textContent = `${done} of ${total} checked`;
    }
  }

  checkItems.forEach(item => {
    const btn = item.querySelector<HTMLButtonElement>('.check-action');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isDone = item.dataset.done === 'true';
      item.dataset.done = isDone ? 'false' : 'true';
      btn.dataset.checked = isDone ? 'false' : 'true';
      btn.textContent = isDone ? '+' : 'OK';
      updateProgress();
    });
  });

  // Initialize
  updateProgress();
</script>

<style>
  .guide-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }
  .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .meta-warn {
    color: var(--color-warning-text);
    border-color: var(--color-warning-border);
    background: var(--color-warning-bg);
  }

  h2 {
    margin-top: 0;
  }

  kbd {
    display: inline-block;
    padding: 1px 5px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface-raised);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .step-card-partial {
    border-left: 3px solid var(--color-warning-text);
  }
  .step-num-partial {
    background: var(--color-warning-text);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-text);
  }
</style>
