---
import ContentLayout from '../layouts/ContentLayout.astro';
import { CURRENT_VERSION, EVIDENCE_REVIEW_DATE } from '../data/site';

const pageSourceIds = ['DB-API-001', 'DB-API-005'];

const checklist = [
  { num: 1, title: 'Game title and platform', body: '<em>[WORLD CUP BETA] Demon Born</em> — available on Roblox. No separate client or download required.' },
  { num: 2, title: 'Creator', body: 'SoraExp (Roblox group). Group ID: <code>34709042</code>. Not affiliated with Bandai Namco or the Demon Slayer IP.' },
  { num: 3, title: 'Genre', body: 'Action RPG. Open-world setting with mysteries and challenging quests — confirmed from official Roblox description.' },
  { num: 4, title: 'Two player routes exist', body: 'Official wording: become a <strong>Slayer</strong> (fight demons) or <strong>Demon</strong> (embrace the dark side and fight to destroy humanity). Specific route differences — stat allocations, abilities, quest branching, endings — are not documented in official sources yet.' },
  { num: 5, title: 'Controls — key labels confirmed', body: '9 keys confirmed from official description: <kbd>Left Click</kbd> Attack · <kbd>Q</kbd> Dash · <kbd>F</kbd> Defense · <kbd>ALT</kbd> Lock · <kbd>B</kbd> Finish · <kbd>H</kbd> Breathing · <kbd>U</kbd> Quest Indicators · <kbd>M</kbd> Menu · <kbd>SHIFT</kbd> Run. <a href="/controls/">See full Controls page</a> — mechanics (cooldowns, stamina, style effects) are not yet verified.' },
  { num: 6, title: 'Codes — not confirmed yet', body: 'No official code source is confirmed. Active codes and redemption details will be published only after an official source is verified. <a href="/codes/">See Codes Source Checker</a>', partial: true },
  { num: 7, title: 'Wiki and Trello — not confirmed', body: 'No official wiki or Trello board is linked from any verified official Roblox channel. See <a href="/wiki/">Wiki Status</a> and <a href="/trello/">Trello Status</a>.', partial: true },
];

const assetMap = [
  { name: 'Play platform', status: 'Can use now', pillClass: 'pill-now', note: 'Available on Roblox now' },
  { name: 'Controls', status: 'Can use now', pillClass: 'pill-now', note: '9 key labels confirmed' },
  { name: 'Route premise', status: 'Limited', pillClass: 'pill-hold', note: 'Two routes confirmed; details not yet' },
  { name: 'Codes', status: 'Do not trust yet', pillClass: 'pill-blocked', note: 'No official source confirmed' },
  { name: 'Builds', status: 'Do not trust yet', pillClass: 'pill-blocked', note: 'Tier lists and best builds not published' },
  { name: 'First quest', status: 'Do not trust yet', pillClass: 'pill-blocked', note: 'Requires hands-on play to document' },
];
---

<ContentLayout
  title="Demon Born Starter Checklist"
  description="Demon Born starter checklist — safe facts before you play, not a full walkthrough."
  canonicalUrl="/beginner-guide/"
  breadcrumb={[{ label: 'Starter Checklist', url: '/beginner-guide/' }]}
  evidenceNotes="Official confirmed limited — starter facts only; no first quest, stat allocation, or route unlock method published"
  sourceIds={pageSourceIds}
>
  <div class="workstation-container">
    <h1>Demon Born Starter Checklist</h1>

    <!-- Quick Answer Panel -->
    <div class="quick-answer-panel">
      <div class="qap-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Quick Answer
      </div>
      <p class="qap-body">
        This is not a full walkthrough yet. It is a safe starter checklist based only on confirmed public information. Use it to know what is safe to trust before or during your first session.
      </p>
    </div>

    <!-- What you should do now -->
    <h2>What you should do now</h2>
    <div class="step-cards">
      <div class="step-card">
        <div class="step-num">1</div>
        <div class="step-body">Open the <strong>official Roblox game page</strong> and check the description for any pinned codes or updates.</div>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <div class="step-body">Learn the <strong>9 confirmed control keys</strong> — labels are official, mechanics are not verified yet. <a href="/controls/">See Controls page</a>.</div>
      </div>
      <div class="step-card">
        <div class="step-num">3</div>
        <div class="step-body">Choose <strong>Slayer or Demon</strong> as a broad route idea — do not commit to detailed builds or tier choices yet.</div>
      </div>
      <div class="step-card">
        <div class="step-num">4</div>
        <div class="step-body">Avoid <strong>tier lists and build claims</strong> from third-party sites until we can verify them from official sources.</div>
      </div>
    </div>

    <!-- What not to trust yet -->
    <h2>What not to trust yet</h2>
    <div class="dont-trust-grid">
      <div class="dont-trust-item">First quest or tutorial step-by-step guides</div>
      <div class="dont-trust-item">Stat allocation recommendations</div>
      <div class="dont-trust-item">Route unlock methods</div>
      <div class="dont-trust-item">Best clan, best build, or tier list</div>
      <div class="dont-trust-item">Clan or class system details</div>
      <div class="dont-trust-item">Active codes from third-party sites</div>
    </div>

    <!-- Quick status -->
    <div class="guide-meta">
      <span class="meta-chip">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <rect x="1.5" y="1.5" width="9" height="9" rx="2" stroke="currentColor" stroke-width="1.2"/>
          <path d="M4 6h4M4 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        {CURRENT_VERSION}
      </span>
      <span class="meta-chip meta-warn">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M6 2v5M6 9v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
        </svg>
        Detailed steps require hands-on testing
      </span>
      <span class="meta-chip">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Last checked: {EVIDENCE_REVIEW_DATE}
      </span>
    </div>

    <!-- Ready now / Do not trust yet — two column cards -->
    <h2>Can I use this info right now?</h2>
    <div class="can-cannot">
      <div class="can-col">
        <div class="col-heading">Yes — safe to use</div>
        <ul class="col-list">
          <li>Identity, title, creator</li>
          <li>Official control key labels</li>
          <li>Genre and setting (open world)</li>
          <li>Two-route premise (Slayer / Demon)</li>
          <li>Wiki and Trello status check</li>
          <li>Codes source checker</li>
        </ul>
      </div>
      <div class="cannot-col">
        <div class="col-heading">No — do not trust yet</div>
        <ul class="col-list">
          <li>First quest or tutorial steps</li>
          <li>Stat allocation system</li>
          <li>Route unlock method</li>
          <li>Character creation details</li>
          <li>Breathing styles and demon arts</li>
          <li>Clans or class system</li>
          <li>Crafting, mining, fishing</li>
          <li>Active codes (wait for official)</li>
          <li>Tier list or best build</li>
        </ul>
      </div>
    </div>

    <!-- Mini asset map — player language -->
    <h2>Can I use this info? (status map)</h2>
    <div class="asset-map">
      {assetMap.map(a => (
        <div class="asset-item">
          <div>
            <div class="asset-name">{a.name}</div>
            <div style="font-size: 0.75rem; color: var(--color-text-muted);">{a.note}</div>
          </div>
          <span class={`simple-status-pill ${a.pillClass}`}>{a.status}</span>
        </div>
      ))}
    </div>

    <!-- Pre-play checklist — step cards -->
    <h2>Confirmed facts before you play</h2>
    <p style="color: var(--color-text-muted); font-size: 0.9375rem; margin-bottom: var(--space-5)">
      Each item below is confirmed from official Roblox sources. Items marked incomplete need hands-on testing before they are complete.
    </p>
    <div class="step-cards">
      {checklist.map(item => (
        <div class={`step-card ${item.partial ? 'step-card-partial' : ''}`}>
          <div class={`step-num ${item.partial ? 'step-num-partial' : ''}`}>{item.num}</div>
          <div class="step-body">
            <strong>{item.title}</strong>
            <div set:html={item.body} style="margin-top: 4px; color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.55;"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Official resources -->
    <h2>Official resources</h2>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Resource</th>
            <th>URL</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Official game page</td>
            <td><a href="https://www.roblox.com/games/79833666916700/Demon-Born" rel="noopener noreferrer" target="_blank">roblox.com/games/79833666916700/Demon-Born</a></td>
          </tr>
          <tr>
            <td>SoraExp Roblox group</td>
            <td><a href="https://groups.roblox.com/v1/groups/34709042" rel="noopener noreferrer" target="_blank">groups.roblox.com/v1/groups/34709042</a></td>
          </tr>
        </tbody>
      </table>
    </div>

    <p>
      If you have verified official information or hands-on observations to share,
      use the <a href="/contact/">correction workflow</a>.
      All published gameplay facts require either an official source or documented hands-on testing.
    </p>
  </div>
</ContentLayout>

<style>
  .guide-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }
  .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .meta-warn {
    color: var(--color-warning-text);
    border-color: var(--color-warning-border);
    background: var(--color-warning-bg);
  }

  h2 {
    margin-top: 0;
  }

  kbd {
    display: inline-block;
    padding: 1px 5px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface-raised);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .step-card-partial {
    border-left: 3px solid var(--color-warning-text);
  }
  .step-num-partial {
    background: var(--color-warning-text);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-text);
  }
</style>