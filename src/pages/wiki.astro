---
import ContentLayout from '../layouts/ContentLayout.astro';
import { GAME_NAME, EVIDENCE_REVIEW_DATE } from '../data/site';

const pageSourceIds = ['DB-SERP-001', 'DB-SERP-002', 'DB-ROBLOX-001', 'DB-API-001', 'DB-API-009', 'DB-API-010', 'DB-API-011'];

const verifiers = [
  { name: 'Roblox game page', endpoint: 'roblox.com/games/79833666916700', result: 'No wiki/Trello link in description', badge: 'tbd', canFact: false, note: 'No wiki linked' },
  { name: 'Roblox game social links API', endpoint: 'games.roblox.com/v1/games/…/social-links/list', result: '401 — Authentication token missing', badge: 'blocked', canFact: false, note: 'Blocked — do not bypass' },
  { name: 'SoraExp Roblox group page', endpoint: 'groups.roblox.com/v1/groups/34709042', result: 'Group metadata only; no wiki/Trello links', badge: 'tbd', canFact: false, note: 'No wiki linked' },
  { name: 'SoraExp group social links API', endpoint: 'groups.roblox.com/v1/groups/…/social-links', result: '401 — Authentication token missing', badge: 'blocked', canFact: false, note: 'Blocked — do not bypass' },
  { name: 'SoraExp community links API', endpoint: 'apis.roblox.com/community-links/v1/groups/…/community', result: 'Returned empty string', badge: 'empty', canFact: false, note: 'No link confirmed' },
  { name: 'Third-party wiki: demonbornwiki.wiki', endpoint: 'demonbornwiki.wiki', result: 'Wiki exists; not linked from any official channel', badge: 'thirdparty', canFact: false, note: 'Community / third-party only' },
];

const serpResults = [
  { result: 'demonbornwiki.wiki', type: 'Exact-match wiki', verdict: 'thirdparty', label: 'Third-party / community lead' },
  { result: '.fandom.com results', type: 'Fandom wikis (other games)', verdict: 'fake', label: 'Not relevant — wrong game' },
  { result: 'Pocket Tactics, Destructoid', type: 'Third-party guides', verdict: 'tbd', label: 'Partial — beginner guides and codes only' },
  { result: 'YouTube gameplay videos', type: 'Video', verdict: 'tbd', label: 'Orientation — not structured reference' },
  { result: 'Reddit community threads', type: 'Community', verdict: 'tbd', label: 'Leads only — not authoritative' },
];
---

<ContentLayout
  title="Wiki Status"
  description="Demon Born wiki status — official vs third-party wiki verification, blocked endpoints, and how to spot fake wiki links."
  canonicalUrl="/wiki/"
  breadcrumb={[{ label: 'Wiki Status', url: '/wiki/' }]}
  evidenceNotes="No official wiki confirmed; social endpoints blocked/empty; third-party wiki labeled as community"
  sourceIds={pageSourceIds}
>
  <div class="workstation-container">
    <h1>{GAME_NAME} Wiki — Official Verifier</h1>

    <!-- Verdict card -->
    <div class="verdict-card verdict-warn">
      <div class="verdict-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10 6v5M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="verdict-body">
        <strong>No official wiki link confirmed from public official sources.</strong>
        Roblox game social links and group social links endpoints are blocked by authentication. The community wiki <em>demonbornwiki.wiki</em> exists but is labeled third-party/community, not official.
      </div>
    </div>

    <!-- Last checked -->
    <div class="last-checked-strip">
      <span class="strip-item">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Last checked: {EVIDENCE_REVIEW_DATE}
      </span>
    </div>

    <!-- Verifier board -->
    <h2>Link verifier board</h2>
    <div class="verifier-board">
      {verifiers.map(v => (
        <div class="verifier-card">
          <div>
            <div class="verifier-name">{v.name}</div>
            <div class="verifier-endpoint">{v.endpoint}</div>
            <div class="verifier-result">{v.result}</div>
          </div>
          <div class="verifier-right">
            <span class={`verifier-badge badge-${v.badge}`}>{v.note}</span>
            <span class={`verifier-fact-label ${v.canFact ? 'verified' : 'unverified'}`}>
              {v.canFact ? '✓ Can use as fact' : '✗ Cannot use as fact'}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- SERP results as cards -->
    <h2>What search results show ({EVIDENCE_REVIEW_DATE})</h2>
    <div class="verifier-board" style="margin-bottom: var(--space-8)">
      {serpResults.map(s => (
        <div class="verifier-card">
          <div>
            <div class="verifier-name">{s.result}</div>
            <div class="verifier-result">{s.type}</div>
          </div>
          <div class="verifier-right">
            <span class={`verifier-badge badge-${s.verdict === 'fake' ? 'blocked' : s.verdict}`}>{s.label}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Fake wiki risk checklist -->
    <h2>Fake wiki risk checklist</h2>
    <div class="checklist-cards">
      <div class="checklist-card">
        <div class="ck-icon ck-fail" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="ck-body"><strong>Do NOT trust:</strong> Domains ending in <code>.wiki</code>, <code>.fandom.com</code>, or generic <code>roblox.fandom.com</code> unless clearly linked from an official Roblox game page or verified creator channel.</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-pass" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ck-body"><strong>Look for:</strong> Links published on the official Roblox game page description or the verified SoraExp Roblox group page.</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-pass" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ck-body"><strong>Check the URL:</strong> Does it match the official creator's branding? Does the Roblox group ID match SoraExp's verified group ID (<code>34709042</code>)?</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-fail" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="ck-body"><strong>Red flag:</strong> A wiki that lists codes, best builds, tier lists, or boss guides with no cited official source. Verify each fact independently.</div>
      </div>
    </div>

    <!-- Can / Cannot yet -->
    <h2>What this page can and cannot do yet</h2>
    <div class="can-cannot">
      <div class="can-col">
        <div class="col-heading">Can do now</div>
        <ul class="col-list">
          <li>Confirm official game title and creator</li>
          <li>Verify no wiki link on Roblox game page</li>
          <li>Track blocked/empty API endpoints</li>
          <li>Label third-party wikis as community</li>
          <li>Identify SERP supply and gaps</li>
        </ul>
      </div>
      <div class="cannot-col">
        <div class="col-heading">Cannot do yet</div>
        <ul class="col-list">
          <li>Publish any wiki URL as official</li>
          <li>Cite third-party wiki content as fact</li>
          <li>Confirm clan or class system details</li>
          <li>Confirm breathing styles or demon arts mechanics</li>
          <li>Document quest names, dungeons, or bosses</li>
        </ul>
      </div>
    </div>

    <!-- What is not confirmed -->
    <h2>What is not yet confirmed</h2>
    <div class="not-confirmed-cards">
      <div class="not-confirmed-item">Clan or class system details</div>
      <div class="not-confirmed-item">Breathing styles or blood demon arts mechanics</div>
      <div class="not-confirmed-item">Specific quest names, dungeon locations, or boss names</div>
      <div class="not-confirmed-item">Level progression or stat systems beyond official description wording</div>
      <div class="not-confirmed-item">Active codes from an official Roblox or creator channel</div>
      <div class="not-confirmed-item">Official wiki or Trello linked from any official Roblox channel</div>
    </div>

    <p>
      <strong>Demon Born Compass</strong> tracks official source status and publishes only verified facts.
      As official sources are confirmed or gameplay testing becomes available, additional pages will be added within the <a href="/editorial/">editorial policy</a> boundaries.
    </p>
  </div>
</ContentLayout>

<style>
  .verdict-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: 8px;
    margin-bottom: var(--space-5);
    border: 1px solid;
  }
  .verdict-warn {
    background: var(--color-warning-bg);
    border-color: var(--color-warning-border);
    color: var(--color-text);
  }
  .verdict-icon {
    color: var(--color-warning-text);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .verdict-body {
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .last-checked-strip {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }
  .strip-item {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  h2 {
    margin-top: 0;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-text);
  }
</style>