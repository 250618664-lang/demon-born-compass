---
import ContentLayout from '../layouts/ContentLayout.astro';
import { EVIDENCE_REVIEW_DATE } from '../data/site';

const pageSourceIds = ['DB-SERP-001', 'DB-SERP-002', 'DB-ROBLOX-001', 'DB-API-001', 'DB-API-009', 'DB-API-010', 'DB-API-011'];

const verifiers = [
  { name: 'Roblox game page', place: 'roblox.com/games/79833666916700', found: 'No wiki/Trello link in description', trust: 'Cannot trust as official', badge: 'blocked', note: 'No wiki linked' },
  { name: 'Roblox game social links API', place: 'games.roblox.com/v1/games/…/social-links/list', found: 'Not publicly visible — authentication required', trust: 'Cannot use as fact', badge: 'blocked', note: 'Blocked — do not bypass' },
  { name: 'SoraExp Roblox group page', place: 'groups.roblox.com/v1/groups/34709042', found: 'Group metadata only; no wiki/Trello links', trust: 'Cannot use as fact', badge: 'blocked', note: 'No wiki linked' },
  { name: 'SoraExp group social links API', place: 'groups.roblox.com/v1/groups/…/social-links', found: 'Not publicly visible — authentication required', trust: 'Cannot use as fact', badge: 'blocked', note: 'Blocked — do not bypass' },
  { name: 'SoraExp community links API', place: 'apis.roblox.com/community-links/v1/groups/…/community', found: 'Returned empty string', trust: 'Cannot use as fact', badge: 'empty', note: 'No link confirmed' },
  { name: 'Fan wiki: demonbornwiki.wiki', place: 'demonbornwiki.wiki', found: 'Wiki exists; not linked from any official channel', trust: 'Not official — fan page only', badge: 'thirdparty', note: 'Community / third-party only' },
];

const serpResults = [
  { result: 'demonbornwiki.wiki', type: 'Exact-match wiki', verdict: 'thirdparty', label: 'Fan wiki — not official' },
  { result: '.fandom.com results', type: 'Fandom wikis (other games)', verdict: 'fake', label: 'Not relevant — wrong game' },
  { result: 'Pocket Tactics, Destructoid', type: 'Third-party guides', verdict: 'tbd', label: 'Partial — beginner guides and codes only' },
  { result: 'YouTube gameplay videos', type: 'Video', verdict: 'tbd', label: 'Orientation — not structured reference' },
  { result: 'Reddit community threads', type: 'Community', verdict: 'tbd', label: 'Leads only — not authoritative' },
];
---

<ContentLayout
  title="Demon Born Wiki"
  description="Demon Born wiki status — official vs fan wiki check. No official wiki confirmed; how to spot fake wiki links."
  canonicalUrl="/wiki/"
  breadcrumb={[{ label: 'Wiki', url: '/wiki/' }]}
  evidenceNotes="No official wiki confirmed; social endpoints blocked/empty; fan wiki labeled as community"
  sourceIds={pageSourceIds}
>
  <div class="workstation-container">
    <h1>Demon Born Wiki</h1>

    <!-- Quick Answer Panel -->
    <div class="quick-answer-panel">
      <div class="qap-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Quick Answer
      </div>
      <p class="qap-body">
        No official Demon Born wiki link is confirmed from public official sources yet. Fan wiki pages may exist, but they are not official unless the creator links them.
      </p>
    </div>

    <!-- What you should do now -->
    <h2>What you should do now</h2>
    <div class="step-cards">
      <div class="step-card">
        <div class="step-num">1</div>
        <div class="step-body">Use this page to <strong>check whether a wiki is official</strong> before trusting any facts from it.</div>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <div class="step-body">Do not treat a <code>.wiki</code> or <code>.fandom.com</code> page as official unless the creator links it from the Roblox game page or verified group.</div>
      </div>
      <div class="step-card">
        <div class="step-num">3</div>
        <div class="step-body">Use confirmed facts on this site for now — they are traceable to official sources.</div>
      </div>
    </div>

    <!-- What not to trust yet -->
    <h2>What not to trust yet</h2>
    <div class="dont-trust-grid">
      <div class="dont-trust-item">Fan wiki pages claiming complete or verified data</div>
      <div class="dont-trust-item">Best builds, tier lists, or rankings without cited official source</div>
      <div class="dont-trust-item">Wiki pages that copy codes from third-party aggregators</div>
      <div class="dont-trust-item">Any .fandom.com page not clearly linked by the creator</div>
    </div>

    <!-- Official link check — player language -->
    <h2>Official link check</h2>
    <p style="color: var(--color-text-muted); font-size: 0.9375rem; margin-bottom: var(--space-5)">
      Last checked: {EVIDENCE_REVIEW_DATE}. We checked the places where official links would appear.
    </p>
    <div class="verifier-board">
      {verifiers.map(v => (
        <div class="verifier-card">
          <div>
            <div class="verifier-name">{v.name}</div>
            <div class="verifier-endpoint">{v.place}</div>
            <div class="verifier-result">{v.found}</div>
          </div>
          <div class="verifier-right">
            <span class={`verifier-badge badge-${v.badge}`}>{v.note}</span>
            <span class="verifier-fact-label">{v.trust}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- SERP results -->
    <h2>What search results show ({EVIDENCE_REVIEW_DATE})</h2>
    <div class="verifier-board" style="margin-bottom: var(--space-8)">
      {serpResults.map(s => (
        <div class="verifier-card">
          <div>
            <div class="verifier-name">{s.result}</div>
            <div class="verifier-result">{s.type}</div>
          </div>
          <div class="verifier-right">
            <span class={`verifier-badge badge-${s.verdict === 'fake' ? 'blocked' : s.verdict}`}>{s.label}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Fake wiki risk checklist -->
    <h2>How to spot a fake wiki</h2>
    <div class="checklist-cards">
      <div class="checklist-card">
        <div class="ck-icon ck-fail" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="ck-body"><strong>Do NOT trust:</strong> Domains ending in <code>.wiki</code>, <code>.fandom.com</code>, or generic <code>roblox.fandom.com</code> unless clearly linked from an official Roblox game page or verified creator channel.</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-pass" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ck-body"><strong>Look for:</strong> Links published on the official Roblox game page description or the verified SoraExp Roblox group page.</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-pass" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ck-body"><strong>Check the URL:</strong> Does it match the official creator's branding? Does the Roblox group ID match SoraExp's verified group ID (<code>34709042</code>)?</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-fail" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="ck-body"><strong>Red flag:</strong> A wiki that lists codes, best builds, tier lists, or boss guides with no cited official source. Verify each fact independently.</div>
      </div>
    </div>

    <!-- Can / Cannot yet -->
    <h2>What this page can and cannot do yet</h2>
    <div class="can-cannot">
      <div class="can-col">
        <div class="col-heading">Can do now</div>
        <ul class="col-list">
          <li>Confirm official game title and creator</li>
          <li>Verify no wiki link on Roblox game page</li>
          <li>Track places where official links would appear</li>
          <li>Label fan wikis as fan pages</li>
          <li>Identify wiki supply and gaps in search results</li>
        </ul>
      </div>
      <div class="cannot-col">
        <div class="col-heading">Cannot do yet</div>
        <ul class="col-list">
          <li>Publish any wiki URL as official</li>
          <li>Cite fan wiki content as fact</li>
          <li>Confirm clan or class system details</li>
          <li>Confirm breathing styles or demon arts mechanics</li>
          <li>Document quest names, dungeons, or bosses</li>
        </ul>
      </div>
    </div>

    <!-- What is not confirmed -->
    <h2>What is not yet confirmed</h2>
    <div class="not-confirmed-cards">
      <div class="not-confirmed-item">Clan or class system details</div>
      <div class="not-confirmed-item">Breathing styles or blood demon arts mechanics</div>
      <div class="not-confirmed-item">Specific quest names, dungeon locations, or boss names</div>
      <div class="not-confirmed-item">Level progression or stat systems beyond official description wording</div>
      <div class="not-confirmed-item">Active codes from an official Roblox or creator channel</div>
      <div class="not-confirmed-item">Official wiki or Trello linked from any official Roblox channel</div>
    </div>

    <!-- How we checked this -->
    <div class="how-we-checked">
      <div class="how-we-checked-title">How we checked this</div>
      <p style="font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 var(--space-4) 0">
        We checked the Roblox game page description, Roblox Games social links API, SoraExp group page, SoraExp group social links API, and community links API.
        Social links endpoints returned 401 (authentication required) or empty string.
        The fan wiki demonbornwiki.wiki was found to exist but is not linked from any official channel.
        No bypass of authentication requirements was attempted.
      </p>
    </div>

    <p>
      <strong>Demon Born Compass</strong> tracks official source status and publishes only verified facts.
      As official sources are confirmed or gameplay testing becomes available, additional pages will be added within the <a href="/editorial/">editorial policy</a> boundaries.
    </p>
  </div>
</ContentLayout>

<style>
  h2 {
    margin-top: 0;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-text);
  }
</style>