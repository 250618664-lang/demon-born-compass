---
import ContentLayout from '../layouts/ContentLayout.astro';
import { CURRENT_VERSION, EVIDENCE_REVIEW_DATE } from '../data/site';

const pageSourceIds = ['DB-API-001', 'DB-API-005'];

const controls = [
  { key: 'Left Click', action: 'Attack', group: 'Combat', confirmed: 'Key label confirmed', unverified: 'We know the key label, but not exactly how the move works yet — cooldowns, stamina, damage unverified' },
  { key: 'Q', action: 'Dash', group: 'Combat', confirmed: 'Key label confirmed', unverified: 'Cooldown, stamina cost, i-frames not verified' },
  { key: 'F', action: 'Defense', group: 'Combat', confirmed: 'Key label confirmed', unverified: 'Effect and duration not verified' },
  { key: 'B', action: 'Finish', group: 'Combat', confirmed: 'Key label confirmed', unverified: 'Trigger conditions not verified' },
  { key: 'ALT', action: 'Lock', group: 'Combat', confirmed: 'Key label confirmed', unverified: 'Lock behavior and target-switching not verified' },
  { key: 'H', action: 'Breathing', group: 'Combat', confirmed: 'Key label confirmed', unverified: 'Breathing system details (styles, upgrades, effects) not verified' },
  { key: 'SHIFT', action: 'Run', group: 'Movement', confirmed: 'Key label confirmed', unverified: 'Stamina cost and speed not verified' },
  { key: 'U', action: 'Quest Indicators', group: 'Navigation', confirmed: 'Key label confirmed', unverified: 'Indicator behavior not verified' },
  { key: 'M', action: 'Menu', group: 'Navigation', confirmed: 'Key label confirmed', unverified: 'Menu structure not verified' },
];

const groups = ['Combat', 'Movement', 'Navigation'];
const confirmedCount = controls.filter(c => c.confirmed).length;
const unverifiedCount = controls.length;
---

<ContentLayout
  title="Demon Born Controls"
  description="Official controls for Demon Born Roblox — 9 key labels confirmed from Roblox game description; mechanics not verified."
  canonicalUrl="/controls/"
  breadcrumb={[{ label: 'Controls', url: '/controls/' }]}
  evidenceNotes="Keys confirmed official; mechanics unverified — no cooldowns, iframes, style effects, or route-specific controls published"
  sourceIds={pageSourceIds}
>
  <div class="workstation-container">
    <h1>Demon Born Controls</h1>

    <!-- Quick Answer Panel -->
    <div class="quick-answer-panel">
      <div class="qap-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Quick Answer
      </div>
      <p class="qap-body">
        These 9 Demon Born key labels are confirmed from the official Roblox game description. We know what key does what by name — but not exactly how the move works yet.
      </p>
    </div>

    <!-- What you should do now -->
    <h2>What you should do now</h2>
    <div class="step-cards">
      <div class="step-card">
        <div class="step-num">1</div>
        <div class="step-body">Use the <strong>key grid below</strong> while playing — key labels are confirmed.</div>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <div class="step-body">Treat mechanics like <strong>cooldowns, stamina cost, damage, and effects</strong> as unverified until we can test them in-game.</div>
      </div>
    </div>

    <!-- Count cards -->
    <div class="status-grid" style="margin-bottom: var(--space-6)">
      <div class="status-card status-ok">
        <div class="status-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <div class="status-label">{confirmedCount} keys confirmed</div>
          <div class="status-desc">Key labels from official Roblox description</div>
        </div>
      </div>
      <div class="status-card status-warn">
        <div class="status-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v5M7 9v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/></svg>
        </div>
        <div>
          <div class="status-label">{unverifiedCount} mechanics unverified</div>
          <div class="status-desc">Cooldowns, stamina, style effects, class controls</div>
        </div>
      </div>
    </div>

    <!-- Controls intro strip -->
    <div class="controls-intro">
      <span class="version-badge">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <rect x="1.5" y="1.5" width="9" height="9" rx="2" stroke="currentColor" stroke-width="1.2"/>
          <path d="M4 6h4M4 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        {CURRENT_VERSION}
      </span>
      <span class="source-ref">
        Sourced from official Roblox game description · Refreshed {EVIDENCE_REVIEW_DATE}
      </span>
    </div>

    <!-- Keycap grid — primary component, near top -->
    <h2>Controls key grid</h2>
    <div class="keycap-grid">
      {controls.map(c => (
        <div class="keycap-card">
          <div class="keycap-key">{c.key}</div>
          <div class="keycap-info">
            <div class="keycap-action">{c.action}</div>
            <div class="keycap-confirmed">✓ {c.confirmed}</div>
            <div class="keycap-unverified">— {c.unverified}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Grouped tables — secondary, mobile-friendly -->
    {groups.map(group => (
      <div class="control-group">
        <h2>{group}</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Key</th>
                <th>Action</th>
                <th>Confirmed</th>
                <th>What we do not know yet</th>
              </tr>
            </thead>
            <tbody>
              {controls
                .filter(c => c.group === group)
                .map(c => (
                  <tr>
                    <td><kbd>{c.key}</kbd></td>
                    <td>{c.action}</td>
                    <td class="note-confirmed">Key label</td>
                    <td class="note-unverified">{c.unverified}</td>
                  </tr>
                ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}

    <!-- What is not confirmed -->
    <h2>What is not confirmed</h2>
    <div class="not-confirmed-cards">
      <div class="not-confirmed-item">Breathing system details — existence and differences between breathing types are unconfirmed</div>
      <div class="not-confirmed-item">Defense and Dash cooldowns, stamina cost, or i-frames</div>
      <div class="not-confirmed-item">Finish move trigger conditions, damage, or rewards</div>
      <div class="not-confirmed-item">Lock behavior and target-switching rules</div>
      <div class="not-confirmed-item">Any class-specific, clan-specific, or route-specific controls</div>
    </div>

    <!-- How we checked this -->
    <div class="how-we-checked">
      <div class="how-we-checked-title">How we checked this</div>
      <p style="font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 var(--space-4) 0">
        We confirmed these 9 key labels from the official Roblox Games API (DB-API-001) and again on refresh (DB-API-005).
        Mechanics, cooldowns, stamina, style effects, and class-specific controls are not published because they have not been confirmed from official sources or hands-on testing.
      </p>
    </div>

    <!-- Evidence history -->
    <h2>Update history</h2>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Event</th>
            <th>Source</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>2026-06-27</td>
            <td>Initial controls confirmed from Roblox API</td>
            <td><code>DB-API-001</code></td>
          </tr>
          <tr>
            <td>2026-06-29</td>
            <td>API refresh — same controls list confirmed</td>
            <td><code>DB-API-005</code></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</ContentLayout>

<style>
  .controls-intro {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }
  .version-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .source-ref {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .control-group {
    margin-bottom: var(--space-4);
  }
  .control-group h2 {
    margin-top: 0;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
  }

  kbd {
    display: inline-block;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface-raised);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .note-confirmed {
    color: #4caf50;
    font-size: 0.8125rem;
    white-space: nowrap;
  }
  .note-unverified {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }

  h2 {
    margin-top: 0;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-text);
  }
</style>