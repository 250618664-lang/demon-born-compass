---
import ContentLayout from '../layouts/ContentLayout.astro';
import Ads from '../components/Ads.astro';
import { GAME_NAME, CURRENT_VERSION } from '../data/site';

const pageSourceIds = ['DB-API-001'];

// Group controls by category
const controls = [
  { key: 'Left Click', action: 'Attack', group: 'Combat' },
  { key: 'Q', action: 'Dash', group: 'Combat' },
  { key: 'F', action: 'Defense', group: 'Combat' },
  { key: 'B', action: 'Finish', group: 'Combat', note: 'Finish move' },
  { key: 'ALT', action: 'Lock', group: 'Combat', note: 'Target lock' },
  { key: 'H', action: 'Breathing', group: 'Combat', note: 'Breathing mechanic' },
  { key: 'U', action: 'Quest Indicators', group: 'Navigation' },
  { key: 'M', action: 'Menu', group: 'Navigation' },
  { key: 'SHIFT', action: 'Run', group: 'Movement' },
];

const groups = ['Combat', 'Movement', 'Navigation'];
---

<ContentLayout
  title="Controls"
  description="Official controls for Demon Born Roblox — from the Roblox game description (source: DB-API-001)."
  canonicalUrl="/controls/"
  breadcrumb={[{ label: 'Controls', url: '/controls/' }]}
  evidenceNotes="Official Roblox game description — DB-API-001"
  sourceIds={pageSourceIds}
>
  <h1>{GAME_NAME} Controls</h1>

  <div class="controls-intro">
    <span class="version-badge">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <rect x="1.5" y="1.5" width="9" height="9" rx="2" stroke="currentColor" stroke-width="1.2"/>
        <path d="M4 6h4M4 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      {CURRENT_VERSION}
    </span>
    <span class="source-ref">Sourced from official Roblox game description · DB-API-001</span>
  </div>

  {groups.map(group => (
    <div class="control-group">
      <h2>{group}</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Key</th>
              <th>Action</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            {controls
              .filter(c => c.group === group)
              .map(c => (
                <tr>
                  <td><kbd>{c.key}</kbd></td>
                  <td>{c.action}</td>
                  <td class="note-cell">{c.note ? c.note : '—'}</td>
                </tr>
              ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}

  <h2>Notes</h2>
  <ul>
    <li>
      <strong>Breathing (H):</strong> The official description mentions a Breathing key. Full details
      of the breathing system — styles, effects, upgrades — are not yet confirmed from official sources.
    </li>
    <li>
      <strong>Finish (B):</strong> A finish move key is listed. Specific conditions for triggering
      a finish move are not yet documented in official sources.
    </li>
    <li>
      <strong>Defense (F) and Dash (Q):</strong> Standard action-RPG mechanics.
      Specific effects, cooldowns, and interactions are not yet verified from official sources.
    </li>
    <li>
      <strong>Lock (ALT):</strong> Target lock is typical for action RPGs with ranged or directional
      combat. Specific behavior in {GAME_NAME} is not yet tested.
    </li>
  </ul>

  <h2>What is not yet confirmed</h2>
  <ul>
    <li>Breathing styles (water, fire, wind breathing) — existence and differences</li>
    <li>Defense and Dash cooldowns, stamina cost, or i-frames</li>
    <li>Finish move conditions, damage, or rewards</li>
    <li>Any class-specific or clan-specific controls</li>
  </ul>

  <Ads placement="rectangle" />
</ContentLayout>

<style>
.controls-intro {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-8);
  flex-wrap: wrap;
}
.version-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--color-surface-raised);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-text);
}
.source-ref {
  font-size: 0.8125rem;
  color: var(--color-text-muted);
}

.control-group {
  margin-bottom: var(--space-4);
}
.control-group h2 {
  margin-top: 0;
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-text-muted);
  border-bottom: 1px solid var(--color-border);
  padding-bottom: var(--space-2);
}

kbd {
  display: inline-block;
  padding: 2px 8px;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  background: var(--color-surface-raised);
  font-family: var(--font-mono);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-accent);
  white-space: nowrap;
}

.note-cell {
  color: var(--color-text-muted);
  font-size: 0.875rem;
}
</style>
