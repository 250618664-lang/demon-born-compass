---
import ContentLayout from '../layouts/ContentLayout.astro';
import { SITE_TITLE, EVIDENCE_REVIEW_DATE } from '../data/site';

const lastChecked = EVIDENCE_REVIEW_DATE;

// Source type categories with badge color
const sourceGroups = [
  {
    type: 'Official / API',
    badgeClass: 'badge-official',
    badgeIcon: '✓',
    count: 11,
    sources: [
      { id: 'DB-ROBLOX-001', title: '[WORLD CUP BETA] Demon Born Roblox game page', url: 'roblox.com/games/79833666916700', use: 'Title, creator, description, controls, genre, max players', access: 'ALLOW_CRAWL' },
      { id: 'DB-API-001', title: 'Roblox Games API — universe 7326773869', url: 'games.roblox.com/v1/games', use: 'Identity, genre, description, controls, open-world scope, player routes', access: 'ALLOW_API' },
      { id: 'DB-API-002', title: 'Roblox Votes API — universe 7326773869', url: 'games.roblox.com/v1/games/votes', use: 'upVotes and downVotes counts', access: 'ALLOW_API' },
      { id: 'DB-API-003', title: 'SoraExp Roblox Group API — group 34709042', url: 'groups.roblox.com/v1/groups/34709042', use: 'Creator group metadata, member count', access: 'ALLOW_API' },
      { id: 'DB-API-004', title: 'Roblox Badges API — universe 7326773869', url: 'badges.roblox.com/v1/universes/…', use: 'Badge list (returned empty at check time)', access: 'ALLOW_API' },
      { id: 'DB-API-005', title: 'Roblox Games API refresh — 2026-06-29', url: 'games.roblox.com/v1/games', use: 'Same data confirmed; updated timestamp noted', access: 'ALLOW_API' },
      { id: 'DB-API-006', title: 'Roblox Votes API refresh — 2026-06-29', url: 'games.roblox.com/v1/games/votes', use: 'Vote counts refreshed', access: 'ALLOW_API' },
      { id: 'DB-API-007', title: 'SoraExp Group API refresh — 2026-06-29', url: 'groups.roblox.com/v1/groups/34709042', use: 'Member count refreshed; publicEntryAllowed confirmed', access: 'ALLOW_API' },
      { id: 'DB-API-008', title: 'Roblox Badges API refresh — 2026-06-29', url: 'badges.roblox.com/v1/universes/…', use: 'Badge list still empty', access: 'ALLOW_API' },
      { id: 'DB-API-011', title: 'SoraExp community links API', url: 'apis.roblox.com/community-links/v1/groups/34709042/community', use: 'Returned empty string; no official community link confirmed', access: 'ALLOW_API' },
      { id: 'DB-AUTO-001', title: 'Google Autocomplete probes — 2026-06-29', url: 'suggestqueries.google.com', use: 'Root query returned "demon born roblox"; modifier probes did not expand', access: 'MANUAL_REFERENCE_ONLY' },
    ],
  },
  {
    type: 'Search / SERP',
    badgeClass: 'badge-serp',
    badgeIcon: '◉',
    count: 3,
    sources: [
      { id: 'DB-SERP-001', title: 'Google SERP — Demon Born wiki and trello (user-supplied)', url: 'local-screenshots', use: 'SERP gap analysis: mixed results, unrelated Fandom/Trello, exact-match competitor wiki', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-SERP-002', title: 'Google SERP manual refresh — 2026-06-29', url: 'google-search-manual', use: 'Code pages dominate; third-party code lists conflict; no new official links found', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-TRENDS-001', title: 'Google Trends — Demon Born Roblox (user-supplied)', url: 'local-screenshots', use: 'Breakout from near-zero baseline; related queries: codes, wiki, trello', access: 'MANUAL_REFERENCE_ONLY' },
    ],
  },
  {
    type: 'Third-party Leads',
    badgeClass: 'badge-lead',
    badgeIcon: '→',
    count: 12,
    sources: [
      { id: 'DB-LEAD-001', title: 'Pocket Tactics — Demon Born codes June 2026', url: 'pockettactics.com/demon-born-codes', use: 'Code competition lead; snippet notes no active Trello/wiki yet', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-002', title: 'Destructoid — Demon Born codes June 2026', url: 'destructoid.com/demon-born-codes/', use: 'Code competition lead; wiki/Trello/Discord mentions', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-005', title: 'Beebom — Demon Born codes June 2026', url: 'beebom.com/demon-born-codes/', use: 'Code competition lead; freshness and conflict analysis only', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-006', title: 'Pro Game Guides — Demon Born codes June 2026', url: 'progameguides.com/roblox/demon-born-codes/', use: 'Code count lead; conflicts with other third-party lists', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-007', title: 'PCGamesN — Demon Born codes June 2026', url: 'pcgamesn.com/roblox/demon-born/codes', use: 'Mentions Discord/update-log workflow as a lead only', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-008', title: 'RadioTimes — Demon Born codes', url: 'radiotimes.com/technology/gaming/roblox-demon-born-codes/', use: 'Active-code list conflicts with other third-party pages', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-009', title: 'YouTube — Demon Born guide video', url: 'youtube.com/watch?v=Wq2wInXO_R8', use: 'Crafting, mining, beginner tasks lead; requires direct testing', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-010', title: 'GameRant — Demon Born codes', url: 'gamerant.com/demon-born-codes-roblox/', use: 'Mentions Roblox group and Discord as update/code locations; needs official confirmation', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-011', title: 'demonbornwiki.site — Ores & Mining Guide', url: 'demonbornwiki.site/guide/ores-mining/', use: 'Mining/location lead; for player demand awareness only', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-012', title: 'YouTube — Crafting Mining and Fishing Guide', url: 'youtube.com/watch?v=eQdvKsIw1nw', use: 'Crafting/mining/fishing lead; not for route or item details', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-013', title: 'YouTube — Best Breathing Styles and Demon Arts', url: 'youtube.com/watch?v=KlJOBSlCSyc', use: 'Breathing/art/tier-list lead; not usable for "best" or ranking claims', access: 'MANUAL_REFERENCE_ONLY' },
      { id: 'DB-LEAD-014', title: 'Reddit — Beginner Guide Trello & Wiki, Stats, Level', url: 'reddit.com/r/Theclashify/comments/1uda5pm/', use: 'C-level lead only; not treated as factual confirmation', access: 'MANUAL_REFERENCE_ONLY' },
    ],
  },
  {
    type: 'Blocked Endpoints',
    badgeClass: 'badge-blocked',
    badgeIcon: '✗',
    count: 2,
    sources: [
      { id: 'DB-API-009', title: 'SoraExp group social links endpoint', url: 'groups.roblox.com/v1/groups/34709042/social-links', use: '401 — Authentication token missing. Do not bypass login. Cannot confirm Discord/Trello/wiki.', access: 'BLOCKED' },
      { id: 'DB-API-010', title: 'Demon Born game social links endpoint', url: 'games.roblox.com/v1/games/7326773869/social-links/list', use: '401 — Authentication token missing. Do not bypass login. Cannot confirm Discord/Trello/wiki.', access: 'BLOCKED' },
    ],
  },
];

const timeline = [
  { date: '2026-06-27', event: 'Initial evidence pack assembled', detail: 'DB-API-001 through DB-API-004, DB-ROBLOX-001, DB-TRENDS-001, DB-SERP-001, DB-LEAD-001, DB-LEAD-002 confirmed.', type: 'evidence' },
  { date: '2026-06-29', event: 'Roblox API refresh', detail: 'DB-API-005 through DB-API-008 confirmed same controls list and metadata; votes and member count updated.', type: 'api_refresh' },
  { date: '2026-06-29', event: 'Social endpoints checked — blocked/empty', detail: 'DB-API-009 (group social links) and DB-API-010 (game social links) returned 401. DB-API-011 (community endpoint) returned empty string. No bypass attempted.', type: 'blocked' },
  { date: '2026-06-29', event: 'Code SERP conflict observed', detail: 'DB-SERP-002 confirmed multiple third-party code pages with differing active/expired lists and redemption-flow descriptions. Active codes remain unpublished.', type: 'conflict' },
  { date: '2026-06-29', event: 'Google Autocomplete probes', detail: 'DB-AUTO-001: root query returned "demon born roblox"; codes/wiki/trello modifier probes did not expand in this run.', type: 'serp' },
];

---

<ContentLayout
  title="Sources & Corrections"
  description="Public source matrix, blocked endpoints, and update timeline for Demon Born Compass."
  canonicalUrl="/sources/"
>
  <div class="workstation-container">
    <h1>Sources &amp; Corrections</h1>

    <p>
      Every factual claim on <strong>{SITE_TITLE}</strong> traces to a registered source ID.
      This page shows the public source matrix, update timeline, and how to submit corrections.
      Full research notes, screenshots, and project methodology are not published publicly.
    </p>

    <!-- Source counts dashboard -->
    <div class="source-counts">
      <div class="count-chip">
        <span class="count-num">11</span>
        <span class="count-label">Official / API</span>
      </div>
      <div class="count-chip">
        <span class="count-num">3</span>
        <span class="count-label">Search / SERP</span>
      </div>
      <div class="count-chip">
        <span class="count-num">12</span>
        <span class="count-label">Third-party Leads</span>
      </div>
      <div class="count-chip">
        <span class="count-num">2</span>
        <span class="count-label">Blocked Endpoints</span>
      </div>
    </div>

    <!-- Legend -->
    <div class="matrix-legend">
      <span class="legend-item"><span class="badge badge-official">✓ Official/API</span> Confirmed from Roblox platform or official creator channel.</span>
      <span class="legend-item"><span class="badge badge-serp">◉ Search/SERP</span> Google signals used for demand/supply awareness only.</span>
      <span class="legend-item"><span class="badge badge-lead">→ Third-party Lead</span> C-level leads — not published as facts; used for gap analysis.</span>
      <span class="legend-item"><span class="badge badge-blocked">✗ Blocked</span> Endpoint inaccessible — no bypass attempted; auth required.</span>
    </div>

    <!-- Update timeline -->
    <h2>Update timeline</h2>
    <div class="timeline">
      {timeline.map(item => (
        <div class={`timeline-item timeline-${item.type}`}>
          <div class="timeline-date">{item.date}</div>
          <div class="timeline-body">
            <div class="timeline-event">{item.event}</div>
            <div class="timeline-detail">{item.detail}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Public Source Matrix — group cards -->
    <h2>Public source matrix — {lastChecked}</h2>

    {sourceGroups.map(group => (
      <div class="source-group">
        <div class="source-group-header">
          <h3 class="source-group-heading">
            <span class={`badge ${group.badgeClass}`}>{group.badgeIcon} {group.type}</span>
          </h3>
          <span class="source-group-count">{group.count} source{group.count !== 1 ? 's' : ''}</span>
        </div>
        <div class="source-cards">
          {group.sources.map(s => (
            <div class="source-card">
              <div class="source-card-top">
                <code class="source-card-id">{s.id}</code>
                <span class={`access-badge access-${s.access.toLowerCase().replace('_', '-')}`}>{s.access}</span>
              </div>
              <div class="source-card-title">
                {s.url.startsWith('http') ? <a href={s.url} rel="noopener noreferrer" target="_blank">{s.title}</a> : s.title}
              </div>
              <div class="source-card-use">{s.use}</div>
            </div>
          ))}
        </div>
      </div>
    ))}

    <!-- Correction workflow -->
    <h2>Correction workflow</h2>
    <div class="step-cards">
      <div class="step-card">
        <div class="step-num">1</div>
        <div class="step-body">Visit the <a href="/contact/">Contact</a> page.</div>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <div class="step-body">Include the page URL and claim ID if known.</div>
      </div>
      <div class="step-card">
        <div class="step-num">3</div>
        <div class="step-body">Provide an official source URL for the correction (Roblox game page, official API, creator post).</div>
      </div>
      <div class="step-card">
        <div class="step-num">4</div>
        <div class="step-body">Corrections are reviewed against official sources before any page update is made.</div>
      </div>
    </div>

    <!-- What is not published -->
    <h2>What is not published here</h2>
    <div class="not-confirmed-cards">
      <div class="not-confirmed-item">Full research notes, claim registries, or working documents.</div>
      <div class="not-confirmed-item">Screenshots or media from private or third-party sources.</div>
      <div class="not-confirmed-item">Active codes from third-party aggregators.</div>
      <div class="not-confirmed-item">Walkthrough steps, stat allocations, or route-specific details without official or hands-on verification.</div>
      <div class="not-confirmed-item">Tier lists, best builds, or best choices.</div>
    </div>

    <p>
      The full claims registry (<code>claims.yaml</code>) and source log (<code>source-log.csv</code>)
      are not published in the public repository. They are used internally to ensure every published
      fact is traceable to an approved source.
    </p>
  </div>
</ContentLayout>

<style>
  /* Timeline */
  .timeline {
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-6);
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .timeline-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    position: relative;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-6) - 5px);
    top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
  }
  .timeline-evidence::before { border-color: #4caf50; background: rgba(76,175,80,0.2); }
  .timeline-api_refresh::before { border-color: #7070e0; background: rgba(112,112,224,0.2); }
  .timeline-blocked::before { border-color: #e05555; background: rgba(224,85,85,0.2); }
  .timeline-conflict::before { border-color: var(--color-warning-text); background: rgba(201,137,10,0.2); }
  .timeline-serp::before { border-color: var(--color-text-muted); background: rgba(139,144,168,0.2); }

  .timeline-date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    white-space: nowrap;
    padding-top: 2px;
    min-width: 6.5rem;
  }
  .timeline-body {
    font-size: 0.875rem;
  }
  .timeline-event {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }
  .timeline-detail {
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Legend */
  .matrix-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  /* Badges */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
  }
  .badge-official {
    background: rgba(76,175,80,0.15);
    color: #4caf50;
    border: 1px solid rgba(76,175,80,0.3);
  }
  .badge-serp {
    background: rgba(100,100,220,0.15);
    color: #7070e0;
    border: 1px solid rgba(100,100,220,0.3);
  }
  .badge-lead {
    background: rgba(139,144,168,0.15);
    color: var(--color-text-muted);
    border: 1px solid rgba(139,144,168,0.3);
  }
  .badge-blocked {
    background: rgba(224,85,85,0.15);
    color: #e05555;
    border: 1px solid rgba(224,85,85,0.3);
  }

  /* Source groups */
  .source-group {
    margin-bottom: var(--space-8);
  }
  .source-group-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }
  .source-group-heading {
    margin: 0;
  }
  .source-group-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  /* Source cards — desktop-friendly grid */
  .source-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: var(--space-3);
  }
  .source-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .source-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .source-card-id {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-accent);
  }
  .source-card-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .source-card-title a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .source-card-title a:hover {
    text-decoration: underline;
  }
  .source-card-use {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Access badges */
  .access-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 3px;
    white-space: nowrap;
    font-family: var(--font-mono);
  }
  .access-allow-crawl { background: rgba(76,175,80,0.15); color: #4caf50; }
  .access-allow-api { background: rgba(76,175,80,0.15); color: #4caf50; }
  .access-manual-reference-only { background: rgba(100,100,220,0.15); color: #7070e0; }
  .access-blocked { background: rgba(224,85,85,0.15); color: #e05555; }

  h2 {
    margin-top: 0;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-text);
  }
</style>