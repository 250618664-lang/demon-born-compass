---
import ContentLayout from '../layouts/ContentLayout.astro';
import { GAME_NAME, EVIDENCE_REVIEW_DATE } from '../data/site';

const pageSourceIds = ['DB-SERP-001', 'DB-SERP-002', 'DB-API-009', 'DB-API-010', 'DB-API-011', 'DB-LEAD-001', 'DB-LEAD-002'];

const verifiers = [
  { name: 'Roblox game page', place: 'roblox.com/games/79833666916700', found: 'No Trello link in description', trust: 'Cannot use as official', badge: 'blocked', note: 'No Trello linked' },
  { name: 'Roblox game social links', place: 'games.roblox.com/v1/games/…/social-links/list', found: 'Not publicly visible — authentication required', trust: 'Cannot use as fact', badge: 'blocked', note: 'Not publicly visible — do not bypass' },
  { name: 'SoraExp Roblox group page', place: 'groups.roblox.com/v1/groups/34709042', found: 'Group metadata only; no Trello links found', trust: 'Cannot use as official', badge: 'blocked', note: 'No Trello linked' },
  { name: 'SoraExp group social links', place: 'groups.roblox.com/v1/groups/…/social-links', found: 'Not publicly visible — authentication required', trust: 'Cannot use as fact', badge: 'blocked', note: 'Not publicly visible — do not bypass' },
  { name: 'SoraExp community links', place: 'apis.roblox.com/community-links/v1/groups/…/community', found: 'Returned empty — no link confirmed', trust: 'Cannot use as fact', badge: 'empty', note: 'No link confirmed' },
  { name: 'Pocket Tactics article', place: 'pockettactics.com', found: 'Mentions "no active Trello board or wiki yet" at time of writing', trust: 'Lead only — not verified', badge: 'tbd', note: 'Out of date / lead only' },
];

const verifySteps = [
  { num: 1, text: 'Check the official Roblox game page description for any pinned Trello link published by the creator.' },
  { num: 2, text: 'Check the official SoraExp Roblox group page for a pinned Trello URL.' },
  { num: 3, text: 'Treat all other Trello links as unverified unless the creator links them directly.' },
  { num: 4, text: 'Verify the Trello board owner matches the creator\'s branding and is not a fan-created board.' },
];
---

<ContentLayout
  title="Demon Born Trello"
  description="Demon Born Trello board status — no official Trello URL confirmed; how to verify if a Trello link is official."
  canonicalUrl="/trello/"
  breadcrumb={[{ label: 'Trello', url: '/trello/' }]}
  evidenceNotes="No official Trello URL confirmed; social endpoints blocked/empty API checks on record"
  sourceIds={pageSourceIds}
>
  <div class="workstation-container">
    <h1>Demon Born Trello</h1>

    <!-- Quick Answer Panel -->
    <div class="quick-answer-panel">
      <div class="qap-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Quick Answer
      </div>
      <p class="qap-body">
        No official Demon Born Trello link is confirmed yet. Do not trust random Trello links unless they are linked by the creator on the Roblox game page or verified group.
      </p>
    </div>

    <!-- Official link check — player language, lower technical -->
    <h2>Official link check</h2>
    <p style="color: var(--color-text-muted); font-size: 0.9375rem; margin-bottom: var(--space-5)">
      Last checked: {EVIDENCE_REVIEW_DATE}. We checked the places where official Trello links would normally appear.
    </p>
    <div class="verifier-board">
      {verifiers.map(v => (
        <div class="verifier-card">
          <div>
            <div class="verifier-name">{v.name}</div>
            <div class="verifier-endpoint">{v.place}</div>
            <div class="verifier-result">{v.found}</div>
          </div>
          <div class="verifier-right">
            <span class={`verifier-badge badge-${v.badge}`}>{v.note}</span>
            <span class="verifier-fact-label">{v.trust}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- What not to trust yet -->
    <h2>What not to trust yet</h2>
    <div class="dont-trust-grid">
      <div class="dont-trust-item">Trello links from guide sites — not verified as official</div>
      <div class="dont-trust-item">Trello boards not linked by the creator from an official Roblox channel</div>
      <div class="dont-trust-item">Roadmap or update claims from unknown boards</div>
    </div>

    <!-- Step cards: verify in order -->
    <h2>If you find a Trello link, verify in this order</h2>
    <div class="step-cards">
      {verifySteps.map(s => (
        <div class="step-card">
          <div class="step-num">{s.num}</div>
          <div class="step-body" set:html={s.text}></div>
        </div>
      ))}
    </div>

    <!-- Blocked endpoint warning — reduced technical -->
    <div class="status-card status-blocked" style="margin-bottom: var(--space-6)">
      <div class="status-icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </div>
      <div>
        <div class="status-label">Why some links are not publicly visible</div>
        <div class="status-desc">Some Roblox API endpoints require a login session to access — this is intentional. We do not bypass authentication requirements.</div>
      </div>
    </div>

    <!-- Decision panel -->
    <h2>Can we publish a Trello link?</h2>
    <div class="decision-panel">
      <div class="decision-header">Publishing readiness check</div>
      <div class="decision-row">
        <span class="decision-label">Trello link on Roblox game page</span>
        <span class="decision-value val-hold">Not safe yet</span>
      </div>
      <div class="decision-row">
        <span class="decision-label">Trello link on SoraExp group page</span>
        <span class="decision-value val-hold">Not safe yet</span>
      </div>
      <div class="decision-row">
        <span class="decision-label">Community links API result</span>
        <span class="decision-value val-blocked">Not publicly visible</span>
      </div>
    </div>

    <!-- Can / Cannot yet -->
    <h2>What this page can and cannot do yet</h2>
    <div class="can-cannot">
      <div class="can-col">
        <div class="col-heading">Can do now</div>
        <ul class="col-list">
          <li>Confirm official game title and creator</li>
          <li>Track where official links would appear</li>
          <li>Warn against unverified Trello links</li>
          <li>Identify Trello as a content gap</li>
          <li>Guide users through official verification steps</li>
        </ul>
      </div>
      <div class="cannot-col">
        <div class="col-heading">Cannot do yet</div>
        <ul class="col-list">
          <li>Publish any Trello URL as official</li>
          <li>Cite any Trello board content as fact</li>
          <li>Confirm roadmap, features, or update plans</li>
          <li>Document quest structure or game systems</li>
          <li>Link to any Trello as a reference</li>
        </ul>
      </div>
    </div>

    <!-- Alternatives -->
    <h2>While no official Trello exists</h2>
    <div class="card-grid">
      <a href="/wiki/" class="card">
        <h2>Wiki Status</h2>
        <p>Current wiki landscape and official source gaps.</p>
      </a>
      <a href="/codes/" class="card">
        <h2>Codes Status</h2>
        <p>How to check for active codes from official channels.</p>
      </a>
      <a href="/controls/" class="card">
        <h2>Controls</h2>
        <p>Official controls from the Roblox game description.</p>
      </a>
    </div>

    <!-- How we checked this -->
    <div class="how-we-checked">
      <div class="how-we-checked-title">How we checked this</div>
      <p style="font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 var(--space-4) 0">
        We checked the Roblox game page, Roblox Games social links API, SoraExp group page, SoraExp group social links API, and community links API.
        Both social links endpoints returned 401 (authentication required) and the community endpoint returned empty string.
        No bypass of authentication was attempted.
      </p>
    </div>

    <p>
      If you can confirm a Trello board is officially associated with {GAME_NAME} or SoraExp,
      please use the <a href="/contact/">correction workflow</a> with the URL and source.
      Once verified, the Trello Status page will be updated.
    </p>
  </div>
</ContentLayout>

<style>
  h2 {
    margin-top: 0;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-surface-raised);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-text);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }
  .card:hover {
    border-color: var(--color-accent);
    background: var(--color-surface-raised);
    transform: translateY(-1px);
    color: var(--color-text);
  }
  .card h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-accent);
  }
  .card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
