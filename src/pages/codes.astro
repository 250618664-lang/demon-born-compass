---
import ContentLayout from '../layouts/ContentLayout.astro';
import { GAME_NAME } from '../data/site';

const pageSourceIds = ['DB-TRENDS-001', 'DB-SERP-001', 'DB-LEAD-001', 'DB-LEAD-002'];
---

<ContentLayout
  title="Codes Status"
  description="Demon Born codes status — no official code feed confirmed. How to find active codes safely."
  canonicalUrl="/codes/"
  breadcrumb={[{ label: 'Codes Status', url: '/codes/' }]}
  evidenceNotes="No official code source confirmed — third-party code lists are not copied"
  sourceIds={pageSourceIds}
>
  <h1>{GAME_NAME} Codes</h1>

  <!-- Verdict card -->
  <div class="verdict-card verdict-warn">
    <div class="verdict-icon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10 6v5M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="verdict-body">
      <strong>No official code feed confirmed.</strong>
      No active codes are published here because no official Roblox or creator channel has been verified as a code source. Third-party code lists are not copied.
    </div>
  </div>

  <!-- Last checked strip -->
  <div class="last-checked-strip">
    <span class="strip-item">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
        <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      Last checked: 2026-06-27
    </span>
    <span class="strip-sep">·</span>
    <span class="strip-item">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Next check: when official source is reported
    </span>
  </div>

  <!-- Redemption status -->
  <h2>Code redemption status</h2>
  <p>
    No official code feed or in-game redemption flow has been verified yet. The steps below
    are a safe checklist to use only if an official code source or in-game code menu is confirmed.
  </p>
  <ol class="redeem-steps">
    <li>
      <span class="step-num">1</span>
      <div class="step-body">
        <strong>Open the game</strong>
        Launch <em>[WORLD CUP BETA] Demon Born</em> on Roblox.
      </div>
    </li>
    <li>
      <span class="step-num">2</span>
      <div class="step-body">
        <strong>Find the Menu</strong>
        Press <kbd>M</kbd> to open the in-game menu.
      </div>
    </li>
    <li>
      <span class="step-num">3</span>
      <div class="step-body">
        <strong>Look for a Codes or Settings option</strong>
        Check whether the menu contains a Codes or Settings option. This location has not been hands-on verified.
      </div>
    </li>
    <li>
      <span class="step-num">4</span>
      <div class="step-body">
        <strong>Enter your code</strong>
        Only enter codes from a verified official source. Do not copy codes from unverified aggregators.
      </div>
    </li>
    <li>
      <span class="step-num">5</span>
      <div class="step-body">
        <strong>Confirm reward</strong>
        If a redemption flow is confirmed later, this page will document the exact reward confirmation behavior.
      </div>
    </li>
  </ol>

  <!-- Why no codes yet -->
  <h2>Why no codes are published here</h2>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Source</th>
          <th>Status</th>
          <th>Verified?</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Roblox game page description</td>
          <td>No codes listed</td>
          <td><span class="tick">✓</span></td>
        </tr>
        <tr>
          <td>Official Discord or group</td>
          <td>No official Discord confirmed</td>
          <td>—</td>
        </tr>
        <tr>
          <td>Creator Twitter/X or social</td>
          <td>Not yet researched</td>
          <td>—</td>
        </tr>
        <tr>
          <td>In-game redemption UI</td>
          <td>Requires hands-on play</td>
          <td>—</td>
        </tr>
        <tr>
          <td>Third-party aggregator sites</td>
          <td>Not verified; not copied</td>
          <td><span class="cross">✗</span></td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>How to find codes safely</h2>
  <ul>
    <li>Check the official Roblox game page description for any pinned codes.</li>
    <li>Visit the official SoraExp Roblox group page for announcements.</li>
    <li>Check the Roblox game description in-game at the main menu.</li>
    <li>If a creator Discord is confirmed official, check its announcements channel.</li>
  </ul>

  <h2>Submit an official code source</h2>
  <p>
    If you have verified an official Roblox channel that publishes {GAME_NAME} codes,
    use the <a href="/contact/">correction workflow</a> with the URL.
    Once confirmed, the codes page will be updated with active codes and redemption details.
  </p>
</ContentLayout>

<style>
.verdict-card {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  padding: var(--space-5);
  border-radius: 8px;
  margin-bottom: var(--space-5);
  border: 1px solid;
}
.verdict-warn {
  background: var(--color-warning-bg);
  border-color: var(--color-warning-border);
  color: var(--color-text);
}
.verdict-icon {
  color: var(--color-warning-text);
  flex-shrink: 0;
  margin-top: 1px;
}
.verdict-body {
  font-size: 0.9375rem;
  line-height: 1.55;
}

.last-checked-strip {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: 0.8125rem;
  color: var(--color-text-muted);
  margin-bottom: var(--space-8);
  flex-wrap: wrap;
}
.strip-item {
  display: flex;
  align-items: center;
  gap: 5px;
}
.strip-sep { opacity: 0.5; }

.redeem-steps {
  list-style: none;
  padding: 0;
  margin-bottom: var(--space-8);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.redeem-steps li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  margin-bottom: 0;
}
.step-num {
  width: 1.75rem;
  height: 1.75rem;
  border-radius: 50%;
  background: var(--color-accent);
  color: #fff;
  font-size: 0.8125rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}
.step-body {
  font-size: 0.9375rem;
  line-height: 1.55;
  padding-top: 3px;
}
.step-body strong { color: var(--color-text); }

kbd {
  display: inline-block;
  padding: 1px 5px;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  background: var(--color-surface-raised);
  font-family: var(--font-mono);
  font-size: 0.8125rem;
  color: var(--color-text);
}

.tick { color: #4caf50; font-weight: 700; }
.cross { color: #e05555; font-weight: 700; }
</style>
