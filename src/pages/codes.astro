---
import ContentLayout from '../layouts/ContentLayout.astro';
import { GAME_NAME, EVIDENCE_REVIEW_DATE } from '../data/site';

const pageSourceIds = ['DB-SERP-002', 'DB-LEAD-005', 'DB-LEAD-006', 'DB-LEAD-007', 'DB-LEAD-008', 'DB-LEAD-010', 'DB-AUTO-001'];
---

<ContentLayout
  title="Codes Status"
  description="Demon Born codes — source checker. No official code feed confirmed; third-party lists conflict; redemption flow unverified."
  canonicalUrl="/codes/"
  breadcrumb={[{ label: 'Codes Status', url: '/codes/' }]}
  evidenceNotes="Active codes not published — no official source confirmed; third-party lists disagree"
  sourceIds={pageSourceIds}
>
  <div class="workstation-container">
    <h1>{GAME_NAME} Codes — Source Checker</h1>

    <!-- Verdict card -->
    <div class="verdict-card verdict-warn">
      <div class="verdict-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10 6v5M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="verdict-body">
        <strong>No public official code feed confirmed.</strong>
        Active codes are not published here. No official Roblox channel, creator social, or in-game menu has been verified as a code source. Third-party code lists are not copied because they disagree on active/expired codes and redemption flow.
      </div>
    </div>

    <!-- Last checked strip -->
    <div class="last-checked-strip">
      <span class="strip-item">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Last checked: {EVIDENCE_REVIEW_DATE}
      </span>
      <span class="strip-sep">·</span>
      <span class="strip-item">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Next check: when official source is reported
      </span>
    </div>

    <!-- Status cards grid -->
    <div class="status-grid">
      <div class="status-card status-unknown">
        <div class="status-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v5M7 9v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/></svg>
        </div>
        <div>
          <div class="status-label">Official Feed</div>
          <div class="status-desc">Not confirmed — no official channel verified</div>
        </div>
      </div>
      <div class="status-card status-blocked">
        <div class="status-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="status-label">Social Endpoints</div>
          <div class="status-desc">Blocked / Empty — no public URL confirmed</div>
        </div>
      </div>
      <div class="status-card status-unknown">
        <div class="status-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="2" y="3" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M5 6h4M5 8.5h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="status-label">In-game UI</div>
          <div class="status-desc">Needs hands-on testing — menu path unverified</div>
        </div>
      </div>
      <div class="status-card status-warn">
        <div class="status-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1.5L12.5 11.5H1.5L7 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M7 5.5v3M7 10v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="status-label">Third-party Lists</div>
          <div class="status-desc">Conflicting — active/expired codes disagree across sources</div>
        </div>
      </div>
    </div>

    <!-- Decision panel -->
    <h2 style="margin-top: var(--space-8)">Can we publish codes?</h2>
    <div class="decision-panel">
      <div class="decision-header">Publishing readiness check</div>
      <div class="decision-row">
        <span class="decision-label">Active code list</span>
        <span class="decision-value val-hold">HOLD</span>
      </div>
      <div class="decision-row">
        <span class="decision-label">Redemption steps</span>
        <span class="decision-value val-hold">HOLD</span>
      </div>
      <div class="decision-row">
        <span class="decision-label">Official source link</span>
        <span class="decision-value val-source">NEEDS_SOURCE</span>
      </div>
    </div>

    <!-- Conflict cards -->
    <h2>Known conflicts with third-party sources</h2>
    <div class="conflict-cards">
      <div class="conflict-card">
        <div class="conflict-card-title">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M6 1.5L10.5 9.5H1.5L6 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
          Different active code lists
        </div>
        <div class="conflict-card-body">Multiple aggregator pages (June 2026) include different codes, disagree on which are expired, and list different rewards. No single authoritative list exists.</div>
      </div>
      <div class="conflict-card">
        <div class="conflict-card-title">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M6 1.5L10.5 9.5H1.5L6 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
          Conflicting redemption paths
        </div>
        <div class="conflict-card-body">Third-party sources describe different menu paths to redeem codes — some cite the <kbd>M</kbd> key + "Codes" button; others describe a character creation flow. No path is confirmed as official.</div>
      </div>
      <div class="conflict-card">
        <div class="conflict-card-title">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M6 1.5L10.5 9.5H1.5L6 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
          Same code — active vs expired
        </div>
        <div class="conflict-card-body">The same code is listed as active on one aggregator and expired on another as of the same month. Cannot determine which is correct without official verification.</div>
      </div>
    </div>

    <!-- Safe checklist — now as cards -->
    <h2>Safe code-checking checklist</h2>
    <div class="checklist-cards">
      <div class="checklist-card">
        <div class="ck-icon ck-pass" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ck-body">Check the <strong>official Roblox game page description</strong> for pinned codes first.</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-pass" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ck-body">Check the <strong>SoraExp Roblox group</strong> announcements if the group page is accessible.</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-warn" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 2v5M7 9v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/></svg>
        </div>
        <div class="ck-body"><strong>Third-party code sites:</strong> treat as unverified leads only. Different pages give different active/expired lists.</div>
      </div>
      <div class="checklist-card">
        <div class="ck-icon ck-fail" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="ck-body"><strong>Never enter a code</strong> from a site you cannot verify as official. Check the URL domain against the creator's known channels.</div>
      </div>
    </div>

    <!-- What would unlock this page -->
    <div class="unlock-panel">
      <div class="unlock-heading">What would unlock this page?</div>
      <div class="unlock-items">
        <div class="unlock-item">
          <div class="unlock-dot" style="background: #4caf50"></div>
          <span><strong>Official post</strong> — a verified Roblox channel or creator post listing active codes with redemption path</span>
        </div>
        <div class="unlock-item">
          <div class="unlock-dot" style="background: #4caf50"></div>
          <span><strong>Verified in-game UI</strong> — documented menu path and field labels confirmed by hands-on testing</span>
        </div>
        <div class="unlock-item">
          <div class="unlock-dot" style="background: #4caf50"></div>
          <span><strong>Public creator source</strong> — a Discord message, group post, or social media update confirmed as official</span>
        </div>
      </div>
    </div>

    <!-- Submit official source -->
    <h2>Submit an official code source</h2>
    <p>
      If you have verified an official Roblox channel that publishes {GAME_NAME} codes,
      use the <a href="/contact/">correction workflow</a> with the URL and a screenshot of the code announcement.
      Once confirmed against official sources, the codes page will be updated.
    </p>
  </div>
</ContentLayout>

<style>
  .verdict-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: 8px;
    margin-bottom: var(--space-5);
    border: 1px solid;
  }
  .verdict-warn {
    background: var(--color-warning-bg);
    border-color: var(--color-warning-border);
    color: var(--color-text);
  }
  .verdict-icon {
    color: var(--color-warning-text);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .verdict-body {
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .last-checked-strip {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }
  .strip-item {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .strip-sep { opacity: 0.5; }

  h2 {
    margin-top: 0;
  }

  kbd {
    display: inline-block;
    padding: 1px 5px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface-raised);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text);
  }
</style>