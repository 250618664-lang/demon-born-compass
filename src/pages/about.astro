---
import ContentLayout from '../layouts/ContentLayout.astro';
import { SITE_TITLE, GAME_NAME, EVIDENCE_REVIEW_DATE } from '../data/site';
---

<ContentLayout
  title="About"
  description="About Demon Born Compass — an unofficial fan guide for Demon Born Roblox."
  canonicalUrl="/about/"
>
  <div class="workstation-container">
    <h1>About {SITE_TITLE}</h1>

    <!-- Quick Answer -->
    <div class="quick-answer-panel">
      <div class="qap-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Quick Answer
      </div>
      <p class="qap-body">
        <strong>{SITE_TITLE}</strong> is an unofficial fan guide for <strong>{GAME_NAME}</strong> on Roblox.
        Not affiliated with Roblox Corporation or SoraExp. Publishes only officially confirmed facts.
      </p>
    </div>

    <!-- Info cards row -->
    <div class="card-grid" style="margin-top: 22px">
      <div class="info-card">
        <div class="info-card-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.3"/><path d="M9 5.5v4l2.5 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </div>
        <div>
          <strong>Evidence-backed</strong>
          <p>Every published fact traces to an official Roblox source or clearly labeled unverified lead. No AI fabrication.</p>
        </div>
      </div>
      <div class="info-card">
        <div class="info-card-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12M9 3l6 6-6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <strong>What we track</strong>
          <p>Official wiki, Trello, and codes status. Controls confirmed from Roblox description. No tier lists or unverified builds.</p>
        </div>
      </div>
      <div class="info-card">
        <div class="info-card-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </div>
        <div>
          <strong>No ads or tracking</strong>
          <p>No advertisements, analytics scripts, or tracking cookies. Static site deployed to Vercel.</p>
        </div>
      </div>
    </div>

    <!-- What we do / don't do -->
    <div class="can-cannot" style="margin-top: 28px">
      <div class="can-col">
        <div class="col-heading">In scope</div>
        <ul class="col-list">
          <li>Official controls from Roblox description</li>
          <li>Wiki / Trello / codes status and gaps</li>
          <li>Full source registry with claim IDs</li>
          <li>Corrections reviewed against official sources</li>
        </ul>
      </div>
      <div class="cannot-col">
        <div class="col-heading">Out of scope</div>
        <ul class="col-list">
          <li>Codes copied from third-party aggregators</li>
          <li>Tier lists, best builds, best breathing styles</li>
          <li>Unverified wiki or Trello links as official</li>
          <li>Unofficial screenshots or Roblox media</li>
        </ul>
      </div>
    </div>

    <!-- Why this exists -->
    <h2>Why this site exists</h2>
    <p>
      Google Trends and SERP observations show rising interest in <em>Demon Born wiki</em>,
      <em>Trello</em>, and <em>codes</em>. The current SERP is mixed — no authoritative,
      evidence-backed hub exists yet. This site fills that gap with an official-source-only approach
      while the game is in early beta.
    </p>

    <!-- Evidence footer -->
    <div class="evidence-footer">
      <p class="evidence-footer-meta">
        Evidence last reviewed {EVIDENCE_REVIEW_DATE} ·
        <a href="/sources/">Sources registry</a> ·
        <a href="/editorial/">Editorial policy</a>
      </p>
    </div>
  </div>
</ContentLayout>

<style>
  .info-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .info-card-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-accent);
  }
  .info-card strong {
    display: block;
    font-size: 0.9375rem;
    margin-bottom: 4px;
  }
  .info-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }
  h2 {
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }
  .evidence-footer {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .evidence-footer-meta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .evidence-footer-meta a {
    color: var(--color-accent);
  }
</style>