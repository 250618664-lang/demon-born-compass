---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, EVIDENCE_REVIEW_DATE, ADS_ENABLED } from '../data/site';

const lastChecked = EVIDENCE_REVIEW_DATE;

const assetGroups = [
  { group: 'Controls', playerLabel: 'Can use now', pillClass: 'pill-now', items: ['9 official keys listed', 'Mechanics not verified yet'] },
  { group: 'Codes', playerLabel: 'Status only', pillClass: 'pill-hold', items: ['No verified official code source', 'Active codes not published'] },
  { group: 'Wiki / Trello', playerLabel: 'Link check only', pillClass: 'pill-hold', items: ['Official links not confirmed', 'Fan pages labeled as fan pages'] },
  { group: 'Classes / Clans', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['No official data confirmed'] },
  { group: 'Builds / Tier', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['No tier list or best build published'] },
  { group: 'Breathing / Demon Arts', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['H key confirmed; details unverified'] },
  { group: 'Locations / Map', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['No official map or location data'] },
];

const playerCards = [
  { href: '/codes/', title: 'Looking for codes?', desc: 'No verified official code source is public yet. Check what we confirmed before using any code list.', btn: 'Check code status' },
  { href: '/controls/', title: 'Need controls?', desc: '9 key labels confirmed from official Roblox description. Mechanics like cooldown and stamina are not verified yet.', btn: 'See controls' },
  { href: '/beginner-guide/', title: 'Starting the game?', desc: 'Official key labels confirmed. Gameplay details like first quest and stats are still limited.', btn: 'View starter checklist' },
];
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonicalUrl="/"
>
  <main class="shell">

    <!-- Home Task Hub — hero grid -->
    <section class="hero-grid">
      <div class="panel hero">
        <span class="eyebrow"><span class="dot"></span> Home is a task hub</span>
        <h1>Demon Born Help Hub</h1>
        <p class="lead">A normal guide site should not put every guide on one endless page. Home gives players fast routes to the answer they searched for.</p>

        <!-- 3 player task cards -->
        <div class="task-grid">
          <a class="task-card" href={playerCards[0].href}>
            <strong>{playerCards[0].title}</strong>
            <span>{playerCards[0].desc}</span>
          </a>
          <a class="task-card" href={playerCards[1].href}>
            <strong>{playerCards[1].title}</strong>
            <span>{playerCards[1].desc}</span>
          </a>
          <a class="task-card" href={playerCards[2].href}>
            <strong>{playerCards[2].title}</strong>
            <span>{playerCards[2].desc}</span>
          </a>
        </div>
      </div>

      <!-- Side panel -->
      <aside class="panel side">
        <!-- Compact status summary -->
        <div style="margin-bottom: 14px">
          <h2 style="margin: 0 0 12px 0; font-size: 15px">What can I use right now?</h2>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <div style="display: flex; align-items: center; gap: 8px; font-size: 13px;">
              <span style="width: 7px; height: 7px; border-radius: 50%; background: #55e08f; box-shadow: 0 0 8px #55e08f; flex-shrink: 0;"></span>
              <span style="color: var(--muted);">Controls: <strong style="color: var(--text)">can use now</strong></span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px; font-size: 13px;">
              <span style="width: 7px; height: 7px; border-radius: 50%; background: #c9890a; flex-shrink: 0;"></span>
              <span style="color: var(--muted);">Codes: <strong style="color: var(--text)">not safe yet / no official source</strong></span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px; font-size: 13px;">
              <span style="width: 7px; height: 7px; border-radius: 50%; background: #c9890a; flex-shrink: 0;"></span>
              <span style="color: var(--muted);">Wiki/Trello: <strong style="color: var(--text)">link check only</strong></span>
            </div>
          </div>
          <p style="margin: 10px 0 0; font-size: 11px; color: var(--quiet);">Last checked {lastChecked}</p>
        </div>

        <!-- Unofficial disclaimer — lower visual weight -->
        <div style="padding: 12px; background: var(--soft); border: 1px solid var(--line); border-radius: var(--radius);">
          <p style="margin: 0; font-size: 11px; color: var(--quiet); line-height: 1.5;">
            Unofficial evidence-backed guide. Not affiliated with Roblox Corporation or SoraExp.
            {ADS_ENABLED ? 'Third-party ads may appear.' : 'Ads are disabled. No analytics or tracking.'}
          </p>
        </div>
      </aside>
    </section>

    <!-- All pages route cards -->
    <section class="panel section" style="margin-top: 22px">
      <div class="section-head">
        <div><h2 style="margin: 0">All pages</h2><p style="margin: 4px 0 0; color: var(--muted); font-size: 14px;">Pick what you need — each page covers one search intent.</p></div>
        <span class="pill">Quick routes</span>
      </div>
      <div class="route">
        <a href="/codes/"><b>01</b><span><strong>/codes/</strong><br />Codes search intent — source status and safe checklist.</span></a>
        <a href="/controls/"><b>02</b><span><strong>/controls/</strong><br />Key grid with confirmed labels and filter buttons.</span></a>
        <a href="/beginner-guide/"><b>03</b><span><strong>/beginner-guide/</strong><br />Starter checklist and confirmed facts before you play.</span></a>
        <a href="/wiki/"><b>04</b><span><strong>/wiki/</strong><br />Official vs fan wiki — what is safe to trust.</span></a>
        <a href="/trello/"><b>05</b><span><strong>/trello/</strong><br />Official Trello link check — no unverified links published.</span></a>
        <a href="/sources/"><b>06</b><span><strong>/sources/</strong><br />Evidence methods and source registry.</span></a>
      </div>
    </section>

    <!-- Asset status map -->
    <section class="panel section" style="margin-top: 22px">
      <div class="section-head">
        <div><h2 style="margin: 0">Content status map</h2><p style="margin: 4px 0 0; color: var(--muted); font-size: 14px;">What is safe to use and what is still unverified.</p></div>
        <span class="pill">Evidence-safe</span>
      </div>
      <div class="asset-board">
        {assetGroups.map(g => (
          <div class="asset-card">
            <div class="asset-header">
              <span class="asset-group-name">{g.group}</span>
              <span class={`simple-status-pill ${g.pillClass}`}>{g.playerLabel}</span>
            </div>
            <ul class="asset-items">
              {g.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <p class="footer-note">Demon Born Compass — unofficial evidence-backed player guide. Ads are disabled. No analytics or tracking scripts.</p>
  </main>
</BaseLayout>
