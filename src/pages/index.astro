---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, EVIDENCE_REVIEW_DATE, ADS_ENABLED } from '../data/site';

const lastChecked = EVIDENCE_REVIEW_DATE;

const assetGroups = [
  { group: 'Controls', playerLabel: 'Can use now', pillClass: 'pill-now', items: ['9 official keys listed', 'Mechanics not verified yet'] },
  { group: 'Codes', playerLabel: 'Status only', pillClass: 'pill-hold', items: ['No verified official code source', 'Active codes not published'] },
  { group: 'Wiki / Trello', playerLabel: 'Link check only', pillClass: 'pill-hold', items: ['Official links not confirmed', 'Fan pages labeled as fan pages'] },
  { group: 'Classes / Clans', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['No official data confirmed'] },
  { group: 'Builds / Tier', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['No tier list or best build published'] },
  { group: 'Breathing / Demon Arts', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['H key confirmed; details unverified'] },
  { group: 'Locations / Map', playerLabel: 'Do not trust yet', pillClass: 'pill-blocked', items: ['No official map or location data'] },
];

const playerCards = [
  { href: '/codes/', title: 'Looking for codes?', desc: 'No verified official code source is public yet. Check what we confirmed before using any code list.', btn: 'Check code status' },
  { href: '/wiki/', title: 'Looking for wiki or Trello?', desc: 'We separate official links from fan pages and fake results. Only official links get the green light.', btn: 'Check official links' },
  { href: '/beginner-guide/', title: 'Starting the game?', desc: 'Official key labels are confirmed. Gameplay details like first quest and stats are still limited.', btn: 'View starter checklist' },
];
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonicalUrl="/"
>
  <div class="prose-container">

    <div class="info-block" style="margin-bottom: var(--space-4)">
      <strong>Unofficial evidence-backed player guide.</strong>
      Not affiliated with Roblox Corporation, SoraExp, or Demon Born creators.
      {ADS_ENABLED ? 'This site displays third-party ads.' : 'Ads are disabled. No analytics or tracking scripts.'}
    </div>

    <!-- Quick Answer Panel -->
    <div class="quick-answer-panel">
      <div class="qap-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 3.5v2.5l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Quick Answer
      </div>
      <p class="qap-body">
        Use this site to check what is safe to trust about Demon Born right now: codes, wiki, Trello, controls, and starter facts.
      </p>
    </div>

    <!-- Player Action Grid -->
    <h2 class="section-heading" style="margin-top: var(--space-8)">What do you need?</h2>
    <div class="player-action-grid">
      {playerCards.map(card => (
        <a href={card.href} class="player-action-card">
          <h3 class="pac-title">{card.title}</h3>
          <p class="pac-desc">{card.desc}</p>
          <span class="pac-btn">{card.btn} →</span>
        </a>
      ))}
    </div>

    <!-- Asset map — player language -->
    <div class="section-with-label" style="margin-top: var(--space-10)">
      <h2 style="margin: 0">What can I use right now?</h2>
    </div>
    <p style="color: var(--color-text-muted); font-size: 0.9375rem; margin-bottom: var(--space-5)">
      Last checked {lastChecked}. Status reflects what we have confirmed from official sources.
    </p>
    <div class="asset-board">
      {assetGroups.map(g => (
        <div class="asset-card">
          <div class="asset-header">
            <span class="asset-group-name">{g.group}</span>
            <span class={`simple-status-pill ${g.pillClass}`}>{g.playerLabel}</span>
          </div>
          <ul class="asset-items">
            {g.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Quick navigation -->
    <h2 class="section-heading">All pages</h2>
    <div class="card-grid">
      <a href="/codes/" class="card">
        <h2>Codes Status</h2>
        <p>Source checker — what we verified and what we are still waiting on.</p>
      </a>
      <a href="/wiki/" class="card">
        <h2>Wiki Status</h2>
        <p>Official vs fan wiki — what is safe to trust.</p>
      </a>
      <a href="/trello/" class="card">
        <h2>Trello Status</h2>
        <p>Official Trello check — no unverified links published.</p>
      </a>
      <a href="/controls/" class="card">
        <h2>Controls</h2>
        <p>9 confirmed key labels from the official Roblox description.</p>
      </a>
      <a href="/beginner-guide/" class="card">
        <h2>Starter Checklist</h2>
        <p>Safe facts before you play — not a full walkthrough.</p>
      </a>
      <a href="/sources/" class="card">
        <h2>How We Check This</h2>
        <p>Evidence methods, blocked checks, and update timeline.</p>
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  /* Asset board */
  .asset-board {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }
  .asset-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-4);
    border-left-width: 3px;
    border-left-color: var(--color-border);
  }
  .asset-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }
  .asset-group-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .asset-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .asset-items li {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding-left: 0.75rem;
    position: relative;
    margin: 0;
  }
  .asset-items li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-border);
  }

  /* Section headings */
  .section-heading {
    margin-top: var(--space-10);
    margin-bottom: var(--space-3);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .asset-board {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 400px) {
    .asset-board {
      grid-template-columns: 1fr;
    }
  }
</style>